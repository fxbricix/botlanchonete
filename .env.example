# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus dados reais

# Credenciais do DatHost
VITE_DAT_HOST_EMAIL=seu_email@exemplo.com
VITE_DAT_HOST_PASSWORD=sua_senha

# ID do servidor no DatHost
VITE_TRACK_SERVER_ID=seu_server_id

# Intervalo de atualização em segundos (opcional, padrão: 30)
VITE_TRACK_INTERVAL_SEC=30

# IP do servidor para conexão
VITE_SERVER_IP=lanches.dat.gg:26088
